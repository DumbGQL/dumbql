{
  "name": "DumbQL + Angular Sandbox",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "postCreateCommand": "npm ci && node scripts/build-packages.mjs",
  "postStartCommand": "node mock/server.mjs & npm start -- --host 0.0.0.0",
  "forwardPorts": [4000, 4200],
  "portsAttributes": {
    "4000": { "label": "GraphQL Mock API", "onAutoForward": "notify" },
    "4200": { "label": "Angular App", "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "graphql.vscode-graphql",
        "nrwl.angular-console"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
