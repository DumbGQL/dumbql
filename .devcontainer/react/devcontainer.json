{
  "name": "DumbQL + React Sandbox",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "postCreateCommand": "npm ci && node scripts/build-packages.mjs",
  "postStartCommand": "node mock/server.mjs & npm --prefix demos/react run dev -- --host 0.0.0.0",
  "forwardPorts": [4000, 5173],
  "portsAttributes": {
    "4000": { "label": "GraphQL Mock API", "onAutoForward": "notify" },
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "graphql.vscode-graphql"
      ]
    }
  }
}
