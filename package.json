{
  "name": "dumb-keystore",
  "version": "0.0.9",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint \"{src,projects/dumbql}/**/*.{ts,html}\"",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint \"{src,projects/dumbql}/**/*.{ts,html}\" --fix",
    "prepare": "husky",
    "schema:download": "node tools/download-schema.mjs",
    "schema:download:dev": "node tools/download-schema.mjs --endpoint=http://localhost:8080/graphql --output=./schema",
    "ext:build:chrome": "node tools/bundle-extension.mjs chrome",
    "ext:build:firefox": "node tools/bundle-extension.mjs firefox",
    "ext:build": "npm run ext:build:chrome && npm run ext:build:firefox",
    "codegen": "node tools/generate-types.mjs",
    "codegen:config": "node tools/generate-types.mjs",
    "build:packages": "for p in projects/dumbql/*/; do (cd \"$p\" && npx ng-packagr -p ng-package.json); done",
    "build:package:core": "npx ng-packagr -p projects/dumbql/core/ng-package.json",
    "build:package:cache": "npx ng-packagr -p projects/dumbql/cache/ng-package.json",
    "test:react": "vitest run --config vitest.react.config.ts",
    "test:react:watch": "vitest --config vitest.react.config.ts",
    "mock": "echo 'Use: npx dumbql-dev (requires @dumbql/dev-server)'",
    "dev": "echo 'Use: dumbql-dev --proxy http://localhost:4200 & ng serve'",
    "deploy": "bash deploy/deploy.sh",
    "version": "node scripts/version.mjs",
    "version:alpha": "node scripts/version.mjs alpha",
    "version:beta": "node scripts/version.mjs beta",
    "version:rc": "node scripts/version.mjs rc",
    "version:patch": "node scripts/version.mjs patch",
    "version:minor": "node scripts/version.mjs minor",
    "version:major": "node scripts/version.mjs major"
  },
  "lint-staged": {
    "{src,projects/dumbql}/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "{src,projects/dumbql}/**/*.html": [
      "eslint --fix",
      "prettier --write"
    ],
    "{src,projects/dumbql}/**/*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "workspaces": [
    "projects/dumbql/*",
    "demos/angular",
    "demos/react",
    "demos/vue",
    "starters/angular",
    "starters/react",
    "starters/vue"
  ],
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@maskito/angular": "^5.3.1",
    "@maskito/core": "^5.3.1",
    "@maskito/kit": "^5.3.1",
    "@maskito/phone": "^5.3.1",
    "@ng-web-apis/common": "^5.3.0",
    "@ng-web-apis/intersection-observer": "^5.3.0",
    "@ng-web-apis/mutation-observer": "^5.3.0",
    "@ng-web-apis/platform": "^5.3.0",
    "@ng-web-apis/resize-observer": "^5.3.0",
    "@ng-web-apis/screen-orientation": "^5.3.0",
    "@stackblitz/sdk": "^1.11.0",
    "@taiga-ui/cdk": "^5.12.0",
    "@taiga-ui/core": "^5.12.0",
    "@taiga-ui/design-tokens": "~0.306.0",
    "@taiga-ui/event-plugins": "^5.0.0",
    "@taiga-ui/font-watcher": "^0.6.0",
    "@taiga-ui/i18n": "^5.12.0",
    "@taiga-ui/icons": "^5.12.0",
    "@taiga-ui/kit": "^5.12.0",
    "@taiga-ui/polymorpheus": "^5.0.1",
    "@taiga-ui/styles": "^5.12.0",
    "graphql": "^17.0.1",
    "highlight.js": "^11.11.1",
    "less": "^4.6.7",
    "libphonenumber-js": "^1.13.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-service": "^22.0.4",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "graphql-yoga": "^5.21.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.7",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "typescript-language-server": "^5.3.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  }
}
