{
  "name": "@dumbql/cache",
  "version": "0.0.12",
  "description": "Normalized in-memory entity cache for GraphQL — __typename:id keying, GC, persistence, optimistic updates",
  "keywords": [
    "graphql",
    "cache",
    "normalized-cache",
    "dumbql",
    "entity-cache"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./public-api.js",
  "types": "./public-api.d.ts",
  "exports": {
    ".": {
      "types": "./public-api.d.ts",
      "import": "./public-api.js",
      "default": "./public-api.js"
    },
    "./angular": {
      "types": "./angular.d.ts",
      "import": "./angular.js",
      "default": "./angular.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@angular/core": "^22.0.0",
    "rxjs": "~7.8.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  }
}
