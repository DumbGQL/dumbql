{
  "name": "@dumbql/client",
  "version": "0.0.8",
  "description": "Framework-agnostic GraphQL client — fetch-based core for React, Vue, or any JS app",
  "keywords": [
    "graphql",
    "client",
    "fetch",
    "dumbql",
    "framework-agnostic",
    "typescript",
    "graphql-client"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./public-api.js",
  "types": "./public-api.d.ts",
  "exports": {
    ".": {
      "types": "./public-api.d.ts",
      "import": "./public-api.js",
      "default": "./public-api.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "dependencies": {
    "graphql": "^17.0.0"
  },
  "peerDependencies": {
    "@dumbql/cache": "^0.0.3"
  }
}
