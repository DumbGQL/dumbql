{
  "name": "@dumbql/dev-server",
  "version": "1.0.5-beta.3",
  "description": "Unified development server for DumbQL — mock GraphQL backend + frontend proxy, no CORS hassle",
  "keywords": [
    "graphql",
    "dev-server",
    "mock",
    "proxy",
    "dumbql"
  ],
  "license": "MIT",
  "type": "module",
  "main": "public-api.js",
  "types": "public-api.d.ts",
  "exports": {
    ".": "./public-api.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "dumbql-dev": "./bin/dumbql-dev.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "graphql": "^17.0.0",
    "graphql-yoga": "^5.0.0"
  }
}
