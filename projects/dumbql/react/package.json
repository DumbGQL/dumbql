{
  "name": "@dumbql/react",
  "version": "0.0.2-rc.3",
  "description": "React bindings for @dumbql/client — hooks for query, mutate, and subscriptions",
  "keywords": [
    "react",
    "graphql",
    "hooks",
    "dumbql",
    "graphql-client",
    "react-hooks"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./public-api.js",
  "types": "./public-api.d.ts",
  "exports": {
    ".": {
      "types": "./public-api.d.ts",
      "import": "./public-api.js",
      "default": "./public-api.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@dumbql/client": "^0.0.1",
    "graphql": "^17.0.0"
  }
