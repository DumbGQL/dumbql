<h1>Getting Started</h1>

<h2>Install</h2>

<p>
  Install the core package and any satellite packages you need:
</p>

<pre><code>npm install @dumbql/core @dumbql/cache @dumbql/subscriptions</code></pre>

<h2>Configure</h2>

<p>
  Provide the <code>GraphqlService</code> (and cache, if used) in your
  <code>app.config.ts</code>:
</p>

<pre ngNonBindable><code>import &#123; provideDumbqlCore, provideDumbqlCache &#125; from '@dumbql/core';
import &#123; createHttpLink &#125; from '@dumbql/core/links';

export const appConfig: ApplicationConfig = &#123;
  providers: [
    provideDumbqlCore(&#123;
      link: createHttpLink(&#123; uri: '/graphql' &#125;),
    &#125;),
    provideDumbqlCache(),
  ],
&#125;;</code></pre>

<h2>Your First Query</h2>

<p>
  Inject <code>GraphqlService</code> in any component and use the <code>gql</code>
  tag for type-safe queries:
</p>

<pre ngNonBindable><code>import &#123; Component, inject &#125; from '@angular/core';
import &#123; GraphqlService, gql &#125; from '@dumbql/core';

@Component(&#123;
  selector: 'app-books',
  standalone: true,
  template: `&lt;ul&gt;
    @for (b of books(); track b.id) {
      &lt;li&gt;{{ b.title }}&lt;/li&gt;
    &#125;
  &lt;/ul&gt;`,
&#125;)
export class BooksComponent &#123;
  #graphql = inject(GraphqlService);

  readonly books = this.#graphql.query(
    gql`query Books &#123; books &#123; id title &#125; &#125;`,
  );
&#125;</code></pre>

<p>
  The <code>query()</code> method returns a <code>Signal&lt;T | null&gt;</code>
  that automatically refetches when dependencies or variables change.
</p>

<h2>Next Steps</h2>

<ul>
  <li>Add <a routerLink="/docs/cache">caching</a> for normalized data</li>
  <li>Enable <a routerLink="/docs/subscriptions">subscriptions</a> for real-time updates</li>
  <li>Protect your app with <a routerLink="/docs/middlewares">middleware</a> for auth tokens</li>
</ul>
